APP_NAME=myapp
APP_ENV=local
DEBUG=false
DATABASE_URL=postgresql+asyncpg://myapp:changeme@localhost:5432/myapp
DATABASE_TEST_URL=postgresql+asyncpg://myapp:changeme@localhost:5432/myapp_test
CORS_ORIGINS=["http://localhost:3000"]

# Optional object storage (Aliyun OSS)
OSS_ENABLED=false
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=
OSS_MAX_CONNECTIONS=20
OSS_DISABLE_SSL=false
OSS_USE_CNAME=true
OSS_LOAD_MAX_SIZE=52428800
